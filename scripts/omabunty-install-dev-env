#!/bin/bash

# Omabunty Development Environment Installer
# Ubuntu equivalent of omarchy-install-dev-env

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

info() { echo -e "${GREEN}[INFO]${NC} $*"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $*"; }

if [[ -z $1 ]]; then
  echo "Usage: omabunty-install-dev-env <ruby|node|bun|deno|go|php|laravel|symfony|python|rust|java|dotnet|ocaml|zig>"
  exit 1
fi

install_php() {
  info "Installing PHP..."
  sudo apt update
  sudo apt install -y php php-cli php-fpm php-mbstring php-xml php-curl php-zip php-sqlite3 php-intl
}

install_ruby() {
  info "Installing Ruby..."
  sudo apt update
  sudo apt install -y ruby ruby-dev build-essential libffi-dev libyaml-dev
  gem install bundler
}

install_node() {
  info "Installing Node.js..."
  curl -fsSL https://deb.nodesource.com/setup_20.x | sudo bash -
  sudo apt install -y nodejs
}

install_bun() {
  info "Installing Bun..."
  curl -fsSL https://bun.sh/install | bash
  echo 'export PATH="$HOME/.bun/bin:$PATH"' >> ~/.bashrc
}

install_deno() {
  info "Installing Deno..."
  curl -fsSL https://deno.land/install.sh | sh
  echo 'export DENO_INSTALL="$HOME/.deno"' >> ~/.bashrc
  echo 'export PATH="$DENO_INSTALL/bin:$PATH"' >> ~/.bashrc
}

install_go() {
  info "Installing Go..."
  sudo apt update
  sudo apt install -y golang-go
}

install_python() {
  info "Installing Python..."
  sudo apt update
  sudo apt install -y python3 python3-pip python3-venv
  pip3 install --user pipx
  pipx ensurepath
}

install_rust() {
  info "Installing Rust..."
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
  source "$HOME/.cargo/env"
}

install_java() {
  info "Installing Java..."
  sudo apt update
  sudo apt install -y openjdk-17-jdk
}

install_dotnet() {
  info "Installing .NET..."
  wget https://packages.microsoft.com/config/ubuntu/24.04/packages-microsoft-prod.deb -O /tmp/packages-microsoft-prod.deb
  sudo dpkg -i /tmp/packages-microsoft-prod.deb
  sudo apt update
  sudo apt install -y dotnet-sdk-8.0 aspnetcore-runtime-8.0
}

install_ocaml() {
  info "Installing OCaml..."
  sudo apt update
  sudo apt install -y opam m4
  opam init --yes
  eval $(opam env)
  opam install -y ocaml-lsp-server ocamlformat
}

install_zig() {
  info "Installing Zig..."
  wget https://ziglang.org/download/0.13.0/zig-linux-x86_64-0.13.0.tar.xz -O /tmp/zig.tar.xz
  sudo tar -xf /tmp/zig.tar.xz -C /opt
  sudo ln -sf /opt/zig-linux-x86_64-0.13.0/zig /usr/local/bin/zig
}

case "$1" in
  ruby)
    install_ruby
    info "Ruby installed! Run: ruby --version"
    ;;
  node)
    install_node
    info "Node.js installed! Run: node --version"
    ;;
  bun)
    install_bun
    info "Bun installed! Run: bun --version"
    ;;
  deno)
    install_deno
    info "Deno installed! Run: deno --version"
    ;;
  go)
    install_go
    info "Go installed! Run: go version"
    ;;
  php)
    install_php
    info "PHP installed! Run: php --version"
    ;;
  laravel)
    install_php
    install_node
    composer global require laravel/installer
    info "Laravel installed! Run: laravel new myproject"
    ;;
  symfony)
    install_php
    wget https://get.symfony.com/cli/installer -O /tmp/symfony
    chmod +x /tmp/symfony
    sudo mv /tmp/symfony /usr/local/bin/symfony
    info "Symfony installed! Run: symfony new myproject"
    ;;
  python)
    install_python
    info "Python installed! Run: python3 --version"
    ;;
  rust)
    install_rust
    info "Rust installed! Run: rustc --version"
    ;;
  java)
    install_java
    info "Java installed! Run: java --version"
    ;;
  dotnet)
    install_dotnet
    info ".NET installed! Run: dotnet --version"
    ;;
  ocaml)
    install_ocaml
    info "OCaml installed! Run: ocaml"
    ;;
  zig)
    install_zig
    info "Zig installed! Run: zig version"
    ;;
  *)
    warn "Unknown option: $1"
    exit 1
    ;;
esac

info "Development environment '$1' installed successfully!"